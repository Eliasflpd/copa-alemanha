# === OBRIGATÓRIOS ===

# OpenAI — gera a figurinha com IA
OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_2=sk-...   (opcional, para rotação)
# OPENAI_API_KEY_3=sk-...   (opcional, para rotação)

# Neon — banco de dados
DATABASE_URL=postgresql://...

# Vercel Blob — armazena imagens e PDFs
# (configurado automaticamente no Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Resend — envia o email com a figurinha
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Figurinha Copa 2026 <noreply@seudominio.com>

# Stripe — pagamento
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CHECKOUT_URL=/api/checkout

# URL pública do app
NEXT_PUBLIC_APP_URL=https://copa-alemanha.vercel.app

# Admin
ADMIN_TOKEN=sua-senha-secreta-aqui

# === OPCIONAIS ===

# Gmail SMTP (fallback de email)
# SMTP_USER=seu@gmail.com
# SMTP_PASS=app-password-do-gmail
